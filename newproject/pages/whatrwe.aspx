<%@ Page Title="What Are We" Language="C#" MasterPageFile="~/Site1.Master" AutoEventWireup="true" CodeBehind="whatrwe.aspx.cs" Inherits="newproject.Pages.WebForm1" %>
<asp:Content ID="Content1" ContentPlaceHolderID="head" runat="server">
    <link href="../css/StyleSheet1.css" rel="stylesheet" />
</asp:Content>
<asp:Content ID="Content2" ContentPlaceHolderID="ContentPlaceHolder1" runat="server">
    <div class="agriculture-hero">
        <h1 class="main-heading">Agricultural Development Excellence</h1>
        <h2 class="sub-heading">Is What We Are</h2>
        
        <p class="mission-statement">
            Green Wadi will increase global agricultural production to mitigate hunger and malnutrition, 
            pave the way for food self-sufficiency and security; strengthen the rural community and 
            improve its livelihood, while protecting the environment and natural resources.
        </p>

        <div class="principle-grid">
            <div class="principle-card">
                <div class="principle-number">01</div>
                <div class="principle-content">
                    <strong>Developing and introducing suitable agricultural practices, agro-technology, and post-harvest technology.</strong>
                </div>
            </div>

            <div class="principle-card">
                <div class="principle-number">02</div>
                <div class="principle-content">
                    <strong>Enhancing and building capacity</strong> at all levels of the agricultural value chain.
                </div>
            </div>

            <div class="principle-card">
                <div class="principle-number">03</div>
                <div class="principle-content">
                    <strong>Adopting a results and success-oriented approach.</strong>
                </div>
            </div>

            <div class="principle-card">
                <div class="principle-number">04</div>
                <div class="principle-content">
                    <strong>Focusing on customer satisfaction.</strong>
                </div>
            </div>

            <div class="principle-card">
                <div class="principle-number">05</div>
                <div class="principle-content">
                    <strong>Making a long-term commitment</strong> to our customers and their projects.
                </div>
            </div>

            <div class="principle-card">
                <div class="principle-number">06</div>
                <div class="principle-content">
                    <strong>Providing optimal tailor-made solutions</strong> for any given condition.
                </div>
            </div>
        </div>
    </div>
</asp:Content>